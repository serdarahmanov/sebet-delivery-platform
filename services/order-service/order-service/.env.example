# Spring profile
SPRING_PROFILES_ACTIVE=prod

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/orderdb
SPRING_DATASOURCE_USERNAME=order
SPRING_DATASOURCE_PASSWORD=order

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# Instance identity used as the Redis checkout-lock owner.
# Leave unique per running replica.
ORDER_SERVICE_INSTANCE_ID=order-service-local-1

# Internal API shared secret used to validate X-Internal-Key.
ORDER_SERVICE_INTERNAL_SECRET=change-me

# ShedLock uses PostgreSQL to prevent scheduled jobs running on multiple replicas.
ORDER_SERVICE_SHEDLOCK_DEFAULT_LOCK_AT_MOST_FOR=PT10M

# Store service fallback
ORDER_SERVICE_STORE_SERVICE_BASE_URL=http://localhost:8081
ORDER_SERVICE_STORE_SERVICE_FALLBACK_OPEN_TIME=08:00
ORDER_SERVICE_STORE_SERVICE_FALLBACK_CLOSE_TIME=19:00
ORDER_SERVICE_STORE_SERVICE_FALLBACK_WORKING_DAYS=MONDAY,TUESDAY,WEDNESDAY,THURSDAY,FRIDAY,SATURDAY,SUNDAY

# Scheduled order behavior
ORDER_SERVICE_SCHEDULED_ORDER_MIN_LEAD_TIME_MINUTES=60
ORDER_SERVICE_SCHEDULED_ORDER_SLOT_INTERVAL_MINUTES=15
ORDER_SERVICE_SCHEDULED_ORDER_DELIVERY_WINDOW_DURATION_MINUTES=30
ORDER_SERVICE_SCHEDULED_ORDER_MODIFICATION_CUTOFF_MINUTES=40
ORDER_SERVICE_SCHEDULED_ORDER_ACTIVATION_JOB_ENABLED=true
ORDER_SERVICE_SCHEDULED_ORDER_ACTIVATION_JOB_INTERVAL_MS=60000
ORDER_SERVICE_SCHEDULED_ORDER_ACTIVATION_JOB_INITIAL_DELAY_MS=30000
ORDER_SERVICE_SCHEDULED_ORDER_ACTIVATION_JOB_LEAD_TIME=PT30M
ORDER_SERVICE_SCHEDULED_ORDER_ACTIVATION_JOB_BATCH_SIZE=100
ORDER_SERVICE_SCHEDULED_ORDER_ACTIVATION_JOB_LOCK_AT_MOST_FOR=PT5M
ORDER_SERVICE_SCHEDULED_ORDER_ACTIVATION_JOB_LOCK_AT_LEAST_FOR=PT0S

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_TOPIC=checkout-events
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_GROUP_ID=order-service
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_AUTO_STARTUP=true
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_DLT_TOPIC=checkout-events.DLT
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_VALIDATE_TOPICS=true
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_RETRY_INITIAL_INTERVAL_MS=1000
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_RETRY_MULTIPLIER=2.0
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_RETRY_MAX_INTERVAL_MS=10000
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_RETRY_MAX_ATTEMPTS=3
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_IN_PROGRESS_RETRY_INTERVAL_MS=5000
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_IN_PROGRESS_RETRY_MAX_ATTEMPTS=12
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_PROCESSED_EVENTS_IN_PROGRESS_LEASE=PT30S
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_PROCESSED_EVENTS_COMPLETED_RETENTION=PT168H
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_PROCESSED_EVENTS_ABANDONED_IN_PROGRESS_RETENTION=PT1H
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_PROCESSED_EVENTS_CLEANUP_INTERVAL_MS=600000
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_PROCESSED_EVENTS_CLEANUP_LOCK_AT_MOST_FOR=PT5M
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_PROCESSED_EVENTS_CLEANUP_LOCK_AT_LEAST_FOR=PT0S
ORDER_SERVICE_KAFKA_ORDER_EVENTS_TOPIC=order-events
ORDER_SERVICE_KAFKA_ORDER_EVENTS_GROUP_ID=order-service-driver-assignment-projection
ORDER_SERVICE_KAFKA_ORDER_EVENTS_AUTO_STARTUP=true
ORDER_SERVICE_KAFKA_ORDER_EVENTS_DLT_TOPIC=order-events.DLT
ORDER_SERVICE_KAFKA_ORDER_EVENTS_VALIDATE_TOPICS=true

# REST write idempotency cleanup
ORDER_SERVICE_IDEMPOTENCY_COMPLETED_RETENTION=PT168H
ORDER_SERVICE_IDEMPOTENCY_ABANDONED_IN_PROGRESS_RETENTION=PT1H
ORDER_SERVICE_IDEMPOTENCY_CLEANUP_INTERVAL_MS=600000
ORDER_SERVICE_IDEMPOTENCY_CLEANUP_LOCK_AT_MOST_FOR=PT5M
ORDER_SERVICE_IDEMPOTENCY_CLEANUP_LOCK_AT_LEAST_FOR=PT0S

# Topics provisioned outside this Spring Boot app
ORDER_ARRIVED_TOPIC=order.arrived
ORDER_EVENTS_TOPIC=order-events

# Debezium connector / Kafka Connect
ORDER_SERVICE_DB_HOST=localhost
ORDER_SERVICE_DB_PORT=5432
ORDER_SERVICE_DB_NAME=orderdb
ORDER_SERVICE_DEBEZIUM_USER=debezium
ORDER_SERVICE_DEBEZIUM_PASSWORD=debezium
