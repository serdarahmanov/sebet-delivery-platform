# Spring profile
SPRING_PROFILES_ACTIVE=local

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/orderdb
SPRING_DATASOURCE_USERNAME=order
SPRING_DATASOURCE_PASSWORD=order

# Redis
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# Kafka
SPRING_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_TOPIC=checkout-events
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_GROUP_ID=order-service
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_AUTO_STARTUP=true
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_DLT_TOPIC=checkout-events.DLT
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_VALIDATE_TOPICS=true
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_RETRY_INITIAL_INTERVAL_MS=1000
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_RETRY_MULTIPLIER=2.0
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_RETRY_MAX_INTERVAL_MS=10000
ORDER_SERVICE_KAFKA_CHECKOUT_EVENTS_RETRY_MAX_ATTEMPTS=3

# Planned topics
ORDER_ARRIVED_TOPIC=order.arrived
ORDER_EVENTS_TOPIC=order-events
