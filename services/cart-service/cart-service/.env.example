# Spring profile
SPRING_PROFILES_ACTIVE=prod

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/cartdb
SPRING_DATASOURCE_USERNAME=cart
SPRING_DATASOURCE_PASSWORD=cart

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Downstream services
PROMOTION_SERVICE_URL=http://promotion-service:8080
DELIVERY_SERVICE_URL=http://delivery-service:8080

# OpenTelemetry
OTEL_SERVICE_NAME=cart-service
OTEL_SERVICE_VERSION=0.0.1-SNAPSHOT
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=none
OTEL_LOGS_EXPORTER=none
OTEL_PROPAGATORS=tracecontext,baggage
OTEL_TRACES_SAMPLER=parentbased_always_on
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local
